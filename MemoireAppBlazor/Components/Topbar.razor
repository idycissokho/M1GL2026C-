<header class="glass-topbar">
    <div class="topbar-search">
        <div class="search-wrapper">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Rechercher..." class="search-field" @bind="SearchQuery" />
            <kbd class="search-kbd">Ctrl K</kbd>
        </div>
    </div>

    <div class="topbar-actions">
        <button class="action-btn" @onclick="ToggleTheme" title="Thème">
            <span>@(IsDarkMode ? "☀️" : "🌙")</span>
        </button>

        <div class="notification-wrapper">
            <button class="action-btn">
                <span>🔔</span>
                @if (NotificationCount > 0)
                {
                    <span class="notif-badge">@NotificationCount</span>
                }
            </button>
        </div>

        <div class="user-profile">
            <button class="profile-btn" @onclick="ToggleMenu">
                <div class="avatar">@GetInitials()</div>
                <div class="profile-info">
                    <span class="profile-name">@UserName</span>
                    <span class="profile-role">@UserRole</span>
                </div>
                <span class="chevron">▼</span>
            </button>

            @if (ShowMenu)
            {
                <div class="profile-dropdown">
                    <a href="/profil" class="dropdown-link">Mon profil</a>
                    <a href="/parametres" class="dropdown-link">Paramètres</a>
                    <div class="dropdown-divider"></div>
                    <a href="/logout" class="dropdown-link danger">Déconnexion</a>
                </div>
            }
        </div>
    </div>
</header>

@code {
    [Parameter] public EventCallback<bool> OnThemeChange { get; set; }
    
    private string SearchQuery { get; set; } = "";
    private bool IsDarkMode { get; set; } = false;
    private bool ShowMenu { get; set; } = false;
    private int NotificationCount { get; set; } = 3;
    private string UserName { get; set; } = "Admin User";
    private string UserRole { get; set; } = "Administrateur";

    private string GetInitials() => string.Concat(UserName.Split(' ').Select(n => n[0]));

    private async Task ToggleTheme()
    {
        IsDarkMode = !IsDarkMode;
        await OnThemeChange.InvokeAsync(IsDarkMode);
    }

    private void ToggleMenu() => ShowMenu = !ShowMenu;
}

<style>
    .glass-topbar {
        position: fixed;
        top: 0;
        right: 0;
        left: 280px;
        height: 72px;
        background: var(--glass-bg);
        backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid var(--border-light);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 var(--space-8);
        z-index: 90;
        transition: left var(--transition-base);
    }

    .topbar-search {
        flex: 1;
        max-width: 600px;
    }

    .search-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        gap: var(--space-3);
        background: var(--bg-secondary);
        border: 2px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: var(--space-3) var(--space-4);
        transition: all var(--transition-fast);
    }

    .search-wrapper:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.1);
        background: var(--bg-primary);
    }

    .search-icon {
        font-size: var(--text-lg);
    }

    .search-field {
        flex: 1;
        border: none;
        background: transparent;
        font-size: var(--text-sm);
        color: var(--text-primary);
        outline: none;
    }

    .search-kbd {
        padding: var(--space-1) var(--space-2);
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: var(--text-xs);
        font-family: var(--font-mono);
        color: var(--text-tertiary);
    }

    .topbar-actions {
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .action-btn {
        width: 44px;
        height: 44px;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-xl);
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .action-btn:hover {
        background: var(--bg-tertiary);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .notification-wrapper {
        position: relative;
    }

    .notif-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 20px;
        height: 20px;
        background: var(--gradient-card);
        color: var(--white);
        font-size: var(--text-xs);
        font-weight: 700;
        border-radius: var(--radius-full);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-green);
    }

    .user-profile {
        position: relative;
    }

    .profile-btn {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-2);
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .profile-btn:hover {
        background: var(--bg-tertiary);
        box-shadow: var(--shadow-md);
    }

    .avatar {
        width: 40px;
        height: 40px;
        background: var(--gradient-card);
        color: var(--white);
        font-size: var(--text-sm);
        font-weight: 700;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-green);
    }

    .profile-info {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .profile-name {
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--text-primary);
    }

    .profile-role {
        font-size: var(--text-xs);
        color: var(--text-secondary);
    }

    .chevron {
        font-size: var(--text-xs);
        color: var(--text-tertiary);
    }

    .profile-dropdown {
        position: absolute;
        top: calc(100% + var(--space-2));
        right: 0;
        min-width: 220px;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-xl);
        padding: var(--space-2);
        animation: fadeIn var(--transition-fast);
    }

    .dropdown-link {
        display: block;
        padding: var(--space-3) var(--space-4);
        color: var(--text-primary);
        text-decoration: none;
        font-size: var(--text-sm);
        border-radius: var(--radius-md);
        transition: all var(--transition-fast);
    }

    .dropdown-link:hover {
        background: var(--bg-secondary);
        color: var(--primary);
    }

    .dropdown-link.danger:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
    }

    .dropdown-divider {
        height: 1px;
        background: var(--border-color);
        margin: var(--space-2) 0;
    }

    @@media (max-width: 768px) {
        .glass-topbar {
            left: 80px;
        }
        .profile-info {
            display: none;
        }
    }
</style>
