@page "/"
@inject MemoireAppBlazor.Services.ApiClients.MemoireApiClient MemoireApi
@inject MemoireAppBlazor.Services.ApiClients.EtudiantApiClient EtudiantApi
@using MemoireAppBlazor.DTOs
@rendermode InteractiveServer

<PageTitle>Dashboard - MémoireApp</PageTitle>

<div class="dashboard-container animate-fade-in">
    <div class="dashboard-header">
        <div>
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Vue d'ensemble de la gestion des mémoires académiques</p>
        </div>
        @* <button class="btn btn-primary">
            <span>➕</span>
            <span>Nouveau mémoire</span>
        </button> *@
    </div>

    <div class="kpi-grid">
        <KpiCard 
            Value="@TotalMemoires.ToString()" 
            Label="Total Mémoires"
            IconGradient="linear-gradient(135deg, #10b981 0%, #059669 100%)" />

        <KpiCard 
            Value="@MemoiresValides.ToString()" 
            Label="Mémoires Validés"
            IconGradient="linear-gradient(135deg, #34d399 0%, #10b981 100%)" />

        <KpiCard 
            Value="@MemoiresEnAttente.ToString()" 
            Label="En Attente"
            IconGradient="linear-gradient(135deg, #f59e0b 0%, #d97706 100%)" />

        <KpiCard 
            Value="@TotalEtudiants.ToString()" 
            Label="Étudiants Actifs"
            IconGradient="linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)" />
    </div>

    <div class="dashboard-content">
        <div class="content-card">
            <div class="card-header">
                <h2 class="card-title">Derniers mémoires déposés</h2>
                <a href="/memoires" class="card-link">Voir tout →</a>
            </div>

            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Étudiant</th>
                            <th>Encadreur</th>
                            <th>Date</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var memoire in DerniersMemoires)
                        {
                            <tr>
                                <td>
                                    <div class="table-title">@memoire.Titre</div>
                                </td>
                                <td>@memoire.Auteur</td>
                                <td>@memoire.EncadreurNom</td>
                                <td>@memoire.Date.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge badge-@GetStatusClass(memoire.Statut)">
                                        <span class="badge-icon">@GetStatusIcon(memoire.Statut)</span>
                                        @memoire.Statut
                                    </span>
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <button class="action-btn action-view" title="Voir" @onclick="() => ViewMemoire(memoire)">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                <circle cx="12" cy="12" r="3"></circle>
                                            </svg>
                                        </button>
                                        <button class="action-btn action-edit" title="Modifier" @onclick="() => EditMemoire(memoire)">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                            </svg>
                                        </button>
                                        <button class="action-btn action-delete" title="Supprimer" @onclick="() => DeleteMemoire(memoire)">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6"></polyline>
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (ShowViewModal && SelectedMemoire != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">Détails du mémoire</h2>
                <button class="modal-close" @onclick="CloseModals">✕</button>
            </div>
            <div class="modal-body">
                <div class="detail-group">
                    <label class="detail-label">Titre</label>
                    <p class="detail-value">@SelectedMemoire.Titre</p>
                </div>
                <div class="detail-group">
                    <label class="detail-label">Auteur</label>
                    <p class="detail-value">@SelectedMemoire.Auteur</p>
                </div>
                <div class="detail-group">
                    <label class="detail-label">Contenu</label>
                    <p class="detail-value">@SelectedMemoire.Contenu</p>
                </div>
                <div class="detail-row">
                    <div class="detail-group">
                        <label class="detail-label">Encadreur</label>
                        <p class="detail-value">@SelectedMemoire.EncadreurNom</p>
                    </div>
                    <div class="detail-group">
                        <label class="detail-label">Filière</label>
                        <p class="detail-value">@SelectedMemoire.FiliereNom</p>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="detail-group">
                        <label class="detail-label">Date</label>
                        <p class="detail-value">@SelectedMemoire.Date.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div class="detail-group">
                        <label class="detail-label">Statut</label>
                        <span class="badge badge-@GetStatusClass(SelectedMemoire.Statut)">
                            <span class="badge-icon">@GetStatusIcon(SelectedMemoire.Statut)</span>
                            @SelectedMemoire.Statut
                        </span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModals">Fermer</button>
            </div>
        </div>
    </div>
}

@if (ShowEditModal)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">Modifier le mémoire</h2>
                <button class="modal-close" @onclick="CloseModals">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Titre</label>
                    <input type="text" class="form-input" @bind="EditingMemoire.Titre" />
                </div>
                <div class="form-group">
                    <label class="form-label">Auteur</label>
                    <input type="text" class="form-input" @bind="EditingMemoire.Auteur" />
                </div>
                <div class="form-group">
                    <label class="form-label">Contenu</label>
                    <textarea class="form-input" @bind="EditingMemoire.Contenu" rows="4"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Statut</label>
                    <select class="form-input" @bind="EditingMemoire.Statut">
                        <option value="En attente">En attente</option>
                        <option value="Validé">Validé</option>
                        <option value="Rejeté">Rejeté</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModals">Annuler</button>
                <button class="btn btn-primary" @onclick="SaveMemoire">Enregistrer</button>
            </div>
        </div>
    </div>
}

@if (ShowDeleteModal && SelectedMemoire != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">Confirmer la suppression</h2>
                <button class="modal-close" @onclick="CloseModals">✕</button>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer le mémoire <strong>@SelectedMemoire.Titre</strong> ?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModals">Annuler</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">Supprimer</button>
            </div>
        </div>
    </div>
}

@code {
    private int TotalMemoires = 0;
    private int MemoiresValides = 0;
    private int MemoiresEnAttente = 0;
    private int TotalEtudiants = 0;
    private List<MemoireAppBlazor.DTOs.MemoireDto> DerniersMemoires = new();
    
    private bool ShowViewModal = false;
    private bool ShowEditModal = false;
    private bool ShowDeleteModal = false;
    private MemoireDto? SelectedMemoire = null;
    private MemoireDto EditingMemoire = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var memoires = await MemoireApi.GetAllAsync();
        var etudiants = await EtudiantApi.GetAllAsync();

        TotalMemoires = memoires.Count;
        MemoiresValides = memoires.Count(m => m.Statut == "Validé");
        MemoiresEnAttente = memoires.Count(m => m.Statut == "En attente");
        TotalEtudiants = etudiants.Count;
        DerniersMemoires = memoires.OrderByDescending(m => m.Date).Take(5).ToList();
    }

    private void ViewMemoire(MemoireDto memoire)
    {
        SelectedMemoire = memoire;
        ShowViewModal = true;
        StateHasChanged();
    }

    private void EditMemoire(MemoireDto memoire)
    {
        EditingMemoire = new MemoireDto
        {
            Id = memoire.Id,
            Titre = memoire.Titre,
            Auteur = memoire.Auteur,
            Contenu = memoire.Contenu,
            Statut = memoire.Statut,
            Date = memoire.Date,
            FiliereId = memoire.FiliereId,
            FiliereNom = memoire.FiliereNom,
            EncadreurId = memoire.EncadreurId,
            EncadreurNom = memoire.EncadreurNom
        };
        ShowEditModal = true;
    }

    private void DeleteMemoire(MemoireDto memoire)
    {
        SelectedMemoire = memoire;
        ShowDeleteModal = true;
    }

    private async Task SaveMemoire()
    {
        await MemoireApi.UpdateAsync(EditingMemoire.Id, EditingMemoire);
        await LoadData();
        CloseModals();
    }

    private async Task ConfirmDelete()
    {
        if (SelectedMemoire != null)
        {
            await MemoireApi.DeleteAsync(SelectedMemoire.Id);
            await LoadData();
        }
        CloseModals();
    }

    private void CloseModals()
    {
        ShowViewModal = false;
        ShowEditModal = false;
        ShowDeleteModal = false;
        SelectedMemoire = null;
    }

    private string GetStatusClass(string statut) => statut.ToLower() switch
    {
        "validé" => "success",
        "en attente" => "warning",
        "rejeté" => "danger",
        _ => "success"
    };

    private string GetStatusIcon(string statut) => statut.ToLower() switch
    {
        "validé" => "✓",
        "en attente" => "⏱",
        "rejeté" => "✕",
        _ => "•"
    };
}

<style>
    .dashboard-container {
        padding: var(--space-8);
        display: flex;
        flex-direction: column;
        gap: var(--space-8);
    }

    .dashboard-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .page-title {
        font-size: var(--text-4xl);
        font-weight: 800;
        color: var(--text-primary);
        margin: 0;
        line-height: 1.2;
    }

    .page-subtitle {
        font-size: var(--text-base);
        color: var(--text-secondary);
        margin: var(--space-2) 0 0 0;
    }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--space-6);
    }

    .dashboard-content {
        display: grid;
        gap: var(--space-6);
    }

    .content-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        box-shadow: var(--shadow-sm);
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: var(--space-6);
    }

    .card-title {
        font-size: var(--text-2xl);
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .card-link {
        color: var(--primary);
        text-decoration: none;
        font-size: var(--text-sm);
        font-weight: 600;
        transition: all var(--transition-fast);
    }

    .card-link:hover {
        color: var(--primary-dark);
    }

    .table-wrapper {
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table thead {
        background: var(--bg-secondary);
        border-radius: var(--radius-md);
    }

    .data-table th {
        padding: var(--space-4);
        text-align: left;
        font-size: var(--text-xs);
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .data-table td {
        padding: var(--space-4);
        border-bottom: 1px solid var(--border-light);
        font-size: var(--text-sm);
        color: var(--text-primary);
    }

    .data-table tbody tr {
        transition: all var(--transition-fast);
    }

    .data-table tbody tr:hover {
        background: var(--bg-secondary);
    }

    .table-title {
        font-weight: 600;
        color: var(--text-primary);
    }

    .table-actions {
        display: flex;
        gap: var(--space-2);
    }

    .action-btn {
        width: 32px;
        height: 32px;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all var(--transition-fast);
        color: var(--text-secondary);
    }

    .action-btn:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .action-view:hover {
        background: #dbeafe;
        border-color: #3b82f6;
        color: #3b82f6;
    }

    .action-edit:hover {
        background: #d1fae5;
        border-color: var(--primary);
        color: var(--primary);
    }

    .action-delete:hover {
        background: #fee2e2;
        border-color: #ef4444;
        color: #ef4444;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        font-weight: 600;
    }

    .badge-icon {
        font-size: var(--text-sm);
    }

    .badge-success {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-warning {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: var(--bg-card);
        border-radius: var(--radius-xl);
        width: 90%;
        max-width: 600px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: var(--shadow-xl);
    }

    .modal-small {
        max-width: 400px;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-6);
        border-bottom: 1px solid var(--border-color);
    }

    .modal-title {
        font-size: var(--text-2xl);
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .modal-close {
        width: 32px;
        height: 32px;
        background: var(--bg-secondary);
        border: none;
        border-radius: var(--radius-sm);
        font-size: var(--text-xl);
        cursor: pointer;
    }

    .modal-body {
        padding: var(--space-6);
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: var(--space-3);
        padding: var(--space-6);
        border-top: 1px solid var(--border-color);
    }

    .detail-group {
        margin-bottom: var(--space-4);
    }

    .detail-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4);
    }

    .detail-label {
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: var(--space-2);
        display: block;
    }

    .detail-value {
        font-size: var(--text-base);
        color: var(--text-primary);
        margin: 0;
    }

    .form-group {
        margin-bottom: var(--space-4);
    }

    .form-label {
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: var(--space-2);
        display: block;
    }

    .form-input {
        width: 100%;
        padding: var(--space-3) var(--space-4);
        border: 2px solid var(--border-color);
        border-radius: var(--radius-md);
        background: var(--bg-secondary);
        color: var(--text-primary);
        font-size: var(--text-sm);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.1);
    }

    .btn-danger {
        background: #ef4444;
        color: white;
    }

    @@media (max-width: 768px) {
        .dashboard-header {
            flex-direction: column;
            align-items: flex-start;
            gap: var(--space-4);
        }

        .kpi-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
