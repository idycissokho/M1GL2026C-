@page "/Account/Login"
@layout MemoireAppBlazor.Components.Layout.EmptyLayout
@inject MemoireAppBlazor.Services.ApiClients.AuthApiClient AuthApi
@inject MemoireAppBlazor.Services.AuthStateService AuthState
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Connexion - MémoireApp</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">M</div>
            <h1 class="login-title">MémoireApp</h1>
            <p class="login-subtitle">Connectez-vous à votre espace</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="login-error">@errorMessage</div>
        }

        <div class="form-group">
            <label class="form-label">Email</label>
            <input type="email" class="form-input" @bind="Email" placeholder="admin@memoire.sn" />
        </div>
        <div class="form-group">
            <label class="form-label">Mot de passe</label>
            <input type="password" class="form-input" @bind="Password" placeholder="••••••••"
                   @onkeydown="@(async e => { if (e.Key == "Enter") await LoginUser(); })" />
        </div>
        <button class="login-btn" @onclick="LoginUser" disabled="@IsLoading">
            @(IsLoading ? "Connexion..." : "Se connecter")
        </button>
    </div>
</div>

@code {
    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private string? errorMessage;
    private bool IsLoading { get; set; } = false;

    private async Task LoginUser()
    {
        errorMessage = null;
        IsLoading = true;

        var token = await AuthApi.LoginAsync(Email, Password);

        if (token == null)
        {
            errorMessage = "Email ou mot de passe incorrect.";
            IsLoading = false;
            return;
        }

        await JS.InvokeVoidAsync("localStorage.setItem", "jwt_token", token);
        await JS.InvokeVoidAsync("localStorage.setItem", "user_email", Email);
        AuthState.SetAuthenticated(token, Email);
        NavigationManager.NavigateTo("/dashboard", forceLoad: true);
    }
}

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #064e3b 0%, #065f46 50%, #047857 100%);
    }

    .login-card {
        background: white;
        border-radius: 16px;
        padding: 48px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
    }

    .login-header { text-align: center; margin-bottom: 32px; }

    .login-logo {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        font-size: 28px;
        font-weight: 800;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        box-shadow: 0 8px 20px rgba(16, 185, 129, 0.4);
    }

    .login-title { font-size: 24px; font-weight: 800; color: #111827; margin: 0 0 8px; }
    .login-subtitle { font-size: 14px; color: #6b7280; margin: 0; }

    .login-error {
        background: #fee2e2;
        color: #dc2626;
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .form-group { margin-bottom: 20px; }

    .form-label { display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 8px; }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        font-size: 14px;
        color: #111827;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

    .form-input:focus { border-color: #10b981; box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1); }

    .login-btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
    }

    .login-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(16, 185, 129, 0.5); }
    .login-btn:disabled { opacity: 0.7; cursor: not-allowed; }
</style>
