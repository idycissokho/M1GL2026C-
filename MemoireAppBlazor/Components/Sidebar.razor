<aside class="modern-sidebar @(IsCollapsed ? "collapsed" : "")">
    <div class="sidebar-brand">
        <div class="brand-logo">
            <div class="logo-circle">M</div>
            @if (!IsCollapsed)
            {
                <div class="brand-text">
                    <span class="brand-name">MémoireApp</span>
                    <span class="brand-tagline">Academic Excellence</span>
                </div>
            }
        </div>
        <button class="toggle-btn" @onclick="ToggleSidebar">
            <span class="toggle-icon">@(IsCollapsed ? "→" : "←")</span>
        </button>
    </div>

    <nav class="sidebar-menu">
        <NavLink href="/dashboard" class="menu-link" Match="NavLinkMatch.All">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Dashboard</span> }
        </NavLink>

        <NavLink href="/memoires" class="menu-link">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Mémoires</span> }
        </NavLink>

        <NavLink href="/etudiants" class="menu-link">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Étudiants</span> }
        </NavLink>

        <NavLink href="/encadreurs" class="menu-link">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Encadreurs</span> }
        </NavLink>

        <NavLink href="/depots" class="menu-link">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Dépôts</span> }
        </NavLink>

        <NavLink href="/validations" class="menu-link">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Validations</span> }
        </NavLink>

        <NavLink href="/statistiques" class="menu-link">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Statistiques</span> }
        </NavLink>

        <NavLink href="/parametres" class="menu-link">
            <span class="link-indicator"></span>
            <span class="link-icon">◆</span>
            @if (!IsCollapsed) { <span class="link-text">Paramètres</span> }
        </NavLink>
    </nav>
</aside>

@code {
    [Parameter] public EventCallback<bool> OnToggle { get; set; }
    private bool IsCollapsed { get; set; } = false;

    private async Task ToggleSidebar()
    {
        IsCollapsed = !IsCollapsed;
        await OnToggle.InvokeAsync(IsCollapsed);
    }
}

<style>
    .modern-sidebar {
        position: fixed;
        left: 0;
        top: 0;
        height: 100vh;
        width: 280px;
        background: var(--bg-sidebar);
        padding: var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-8);
        transition: width var(--transition-base);
        z-index: 100;
        box-shadow: var(--shadow-xl);
    }

    .modern-sidebar.collapsed {
        width: 80px;
    }

    .sidebar-brand {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: var(--space-6);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .brand-logo {
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .logo-circle {
        width: 48px;
        height: 48px;
        background: var(--gradient-accent);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-2xl);
        font-weight: 800;
        color: var(--white);
        box-shadow: var(--shadow-green);
        animation: pulse 3s infinite;
    }

    .brand-text {
        display: flex;
        flex-direction: column;
    }

    .brand-name {
        font-size: var(--text-lg);
        font-weight: 800;
        color: var(--white);
        line-height: 1.2;
    }

    .brand-tagline {
        font-size: var(--text-xs);
        color: rgba(255, 255, 255, 0.7);
        font-weight: 500;
    }

    .toggle-btn {
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-sm);
        color: var(--white);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all var(--transition-fast);
        backdrop-filter: blur(10px);
    }

    .toggle-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.1);
    }

    .toggle-icon {
        font-size: var(--text-lg);
        font-weight: 700;
    }

    .sidebar-menu {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .menu-link {
        position: relative;
        display: flex;
        align-items: center;
        gap: var(--space-4);
        padding: var(--space-4);
        border-radius: var(--radius-md);
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: var(--text-sm);
        font-weight: 600;
        transition: all var(--transition-fast);
        overflow: hidden;
    }

    .link-indicator {
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%) scaleY(0);
        width: 4px;
        height: 70%;
        background: var(--gradient-accent);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        transition: transform var(--transition-fast);
    }

    .link-icon {
        font-size: var(--text-sm);
        transition: all var(--transition-fast);
    }

    .menu-link:hover {
        background: rgba(255, 255, 255, 0.1);
        color: var(--white);
        transform: translateX(4px);
    }

    .menu-link:hover .link-icon {
        transform: scale(1.2);
    }

    .menu-link.active {
        background: var(--gradient-accent);
        color: var(--white);
        box-shadow: var(--shadow-green);
    }

    .menu-link.active .link-indicator {
        transform: translateY(-50%) scaleY(1);
    }

    .modern-sidebar.collapsed .brand-text,
    .modern-sidebar.collapsed .link-text {
        display: none;
    }

    @@media (max-width: 768px) {
        .modern-sidebar {
            width: 80px;
        }
        .brand-text, .link-text {
            display: none;
        }
    }
</style>
