<div class="kpi-card @CssClass">
    <div class="kpi-header">
        <div class="kpi-icon-wrapper" style="background: @IconGradient;">
            <span class="kpi-icon">@Icon</span>
        </div>
        @if (!string.IsNullOrEmpty(Trend))
        {
            <span class="kpi-trend @TrendClass">@Trend</span>
        }
    </div>
    <div class="kpi-body">
        <h3 class="kpi-value">@Value</h3>
        <p class="kpi-label">@Label</p>
    </div>
</div>

@code {
    [Parameter] public string Icon { get; set; } = "📊";
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string Label { get; set; } = "Total";
    [Parameter] public string Trend { get; set; } = "";
    [Parameter] public string IconGradient { get; set; } = "linear-gradient(135deg, #10b981 0%, #059669 100%)";
    [Parameter] public string CssClass { get; set; } = "";
    
    private string TrendClass => Trend.StartsWith("+") ? "trend-up" : "trend-down";
}

<style>
    .kpi-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        transition: all var(--transition-base);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gradient-card);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform var(--transition-base);
    }

    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-xl);
        border-color: var(--primary);
    }

    .kpi-card:hover::before {
        transform: scaleX(1);
    }

    .kpi-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: var(--space-4);
    }

    .kpi-icon-wrapper {
        width: 56px;
        height: 56px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-green);
    }

    .kpi-icon {
        font-size: var(--text-3xl);
    }

    .kpi-trend {
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        font-weight: 700;
    }

    .trend-up {
        background: rgba(16, 185, 129, 0.1);
        color: var(--green-700);
    }

    .trend-down {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
    }

    .kpi-body {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .kpi-value {
        font-size: var(--text-4xl);
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1;
    }

    .kpi-label {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        font-weight: 500;
    }
</style>
